{
  "name": "dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "postCreateCommand": "curl -sL https://raw.githubusercontent.com/newren/git-filter-repo/v2.47.0/git-filter-repo -o /usr/local/bin/git-filter-repo && chmod +x /usr/local/bin/git-filter-repo",
  "remoteEnv": {
    "GITLAB_TOKEN": "${localEnv:GITLAB_TOKEN}"
  }
}
