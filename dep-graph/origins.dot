digraph osp_origins {
  rankdir=LR;
  node [fontname="Helvetica", fontsize=10];
  edge [fontsize=8];

  // OSP-bound repos (source nodes)
  "btrfs-dwarfs-framework" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "eggs-ai" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "eggs-gui" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "immutable-linux-framework" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "liquorix-unified-kernel" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "liqxanmod" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "lkf" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "lkm" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "oa-tools" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-eggs" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-eggs-audit" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-eggs-book" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-incus-platform" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-kernel-manager" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-powerwash" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "penguins-recovery" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "ukm" [shape=ellipse, style=filled, fillcolor="#ddffdd"];
  "xanmod-unified-kernel" [shape=ellipse, style=filled, fillcolor="#ddffdd"];

  // Edges and external nodes
  "charmbracelet__bubbletea" [label="charmbracelet/bubbletea", shape=box, style=filled, fillcolor="#ddeeff"];
  "eggs-gui" -> "charmbracelet__bubbletea";
  "jlendres__eggsmaker" [label="jlendres/eggsmaker", shape=box, style=filled, fillcolor="#ddeeff"];
  "eggs-gui" -> "jlendres__eggsmaker";
  "nodegui__nodegui" [label="nodegui/nodegui", shape=box, style=filled, fillcolor="#ddeeff"];
  "eggs-gui" -> "nodegui__nodegui";
  "pieroproietti__eggsmaker" [label="pieroproietti/eggsmaker", shape=box, style=filled, fillcolor="#ddeeff"];
  "eggs-gui" -> "pieroproietti__eggsmaker";
  "pieroproietti__pengui" [label="pieroproietti/pengui", shape=box, style=filled, fillcolor="#ddeeff"];
  "eggs-gui" -> "pieroproietti__pengui";

}
